# ============================================================
# ShopDash — Environment variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (ห้าม commit .env.local)
# ============================================================

# --- Supabase ---
# Supabase Dashboard → Project Settings → API
# URL + anon key ใช้ฝั่ง client ได้ (NEXT_PUBLIC_)
# service_role key ใช้เฉพาะฝั่ง server เท่านั้น — ห้ามหลุดลง browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (S3-compatible object storage) ---
# Cloudflare Dashboard → R2 → Overview (Account ID อยู่แถบขวา)
# Access key: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
# R2_PUBLIC_BASE_URL = public bucket domain เช่น https://pub-xxxx.r2.dev
#   (เปิดที่ bucket → Settings → Public access) หรือ custom CDN domain — ไม่มี / ต่อท้าย
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=shopdash-prod
R2_PUBLIC_BASE_URL=

# --- Platform PromptPay (ค่าแพลนที่ร้านจ่ายให้แพลตฟอร์ม — ใช้จริง Phase 3) ---
# เบอร์มือถือ 10 หลัก หรือเลขบัตรประชาชน 13 หลัก
PLATFORM_PROMPTPAY_ID=
PLATFORM_PROMPTPAY_NAME=

# --- App ---
ROOT_DOMAIN=shopdash.co
# secret สำหรับ Vercel Cron เรียก endpoint (ใช้จริง Phase 3) — gen ด้วย: openssl rand -hex 32
CRON_SECRET=

# --- Slip Verify (ใช้จริง Phase 4 — ตอนนี้คงค่า mock ไว้) ---
SLIP_VERIFY_PROVIDER=mock
SLIP_VERIFY_MOCK_MODE=pass
