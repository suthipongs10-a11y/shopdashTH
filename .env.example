# ============================================================
# ShopDash — Environment variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (ห้าม commit .env.local)
# ============================================================

# --- Supabase ---
# Supabase Dashboard → Project Settings → API
# URL + anon key ใช้ฝั่ง client ได้ (NEXT_PUBLIC_)
# service_role key ใช้เฉพาะฝั่ง server เท่านั้น — ห้ามหลุดลง browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (S3-compatible object storage) ---
# Cloudflare Dashboard → R2 → Overview (Account ID อยู่แถบขวา)
# Access key: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
# R2_PUBLIC_BASE_URL = public bucket domain เช่น https://pub-xxxx.r2.dev
#   (เปิดที่ bucket → Settings → Public access) หรือ custom CDN domain — ไม่มี / ต่อท้าย
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=shopdash-prod
R2_PUBLIC_BASE_URL=

# --- Platform PromptPay (ค่าแพลนที่ร้านจ่ายให้แพลตฟอร์ม — ใช้จริง Phase 3) ---
# เบอร์มือถือ 10 หลัก หรือเลขบัตรประชาชน 13 หลัก
PLATFORM_PROMPTPAY_ID=
PLATFORM_PROMPTPAY_NAME=
# LINE OA ของแพลตฟอร์ม (แจ้งเตือนเจ้าของเมื่อมีร้านใหม่/สลิปค่าแพลน) — ตั้งจาก Super Admin > ตั้งค่า ได้เช่นกัน
PLATFORM_LINE_CHANNEL_TOKEN=

# --- App ---
ROOT_DOMAIN=shopdashth.com
# secret สำหรับ Vercel Cron เรียก endpoint (ใช้จริง Phase 3) — gen ด้วย: openssl rand -hex 32
CRON_SECRET=

# secret ที่ Cloudflare Worker (workers/tenant-proxy.js) ใช้เซ็น header host ร้านจริง
# ตั้งค่าเดียวกันทั้งที่นี่ (Vercel) และใน Worker — ดู workers/README.md
# จำเป็นเฉพาะ production ที่ subdomain ร้านวิ่งผ่าน Cloudflare Worker (ไม่ต้องตั้งใน dev)
TENANT_PROXY_SECRET=

# --- Slip Verify (Phase 4) ---
# ยังไม่มี provider จริง — lib/slip-verify/index.ts fallback เป็น MockSlipVerifier เสมอ
#
# ⛔ PRODUCTION: ห้ามตั้ง SLIP_VERIFY_MOCK_MODE=pass
#    mock โหมด pass จะ "auto-approve ทุกสลิป" → ร้าน Premium ที่เปิด slip_verify_api
#    จะรับสลิปปลอมทันที (ตัดสต๊อก + ยืนยันออร์เดอร์โดยไม่มีเงินเข้าจริง)
#    ใช้ amount_mismatch เพื่อบังคับให้ทุกสลิปตกคิวตรวจด้วยมือ (ปลอดภัย ดู DEPLOYMENT.md §0)
#
# dev: ตั้ง pass ได้เพื่อทดสอบ flow auto-approve
SLIP_VERIFY_PROVIDER=mock
SLIP_VERIFY_MOCK_MODE=amount_mismatch

# --- Test hooks (ห้ามตั้งใน production) ---
# ข้ามการเช็ค DNS จริงของ custom domain แล้วให้ผ่านทุกข้อ (lib/domains.ts)
# DOMAIN_VERIFY_MOCK=pass

# Upstash Redis (optional) — rate limit นับรวมทุก instance บน serverless (ว่าง = นับ in-memory ต่อ instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
